generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  role      Role     @default(dealer)
  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  dealer    Dealer?
}

model Dealer {
  id                   Int            @id @default(autoincrement())
  userId               Int            @unique
  companyName          String
  phone                String?
  address              String?
  contractUrl          String?
  contractStatus       ContractStatus @default(pending)
  createdAt            DateTime       @default(now())
  statusChangedByEmail String?
  statusChangedAt      DateTime?
  user                 User           @relation(fields: [userId], references: [id])
  contracts            Contract[]
  orders               Order[]
}

model Contract {
  id        Int            @id @default(autoincrement())
  dealerId  Int
  fileName  String
  fileUrl   String
  status    ContractStatus @default(pending)
  type      String
  notes     String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  dealer    Dealer         @relation(fields: [dealerId], references: [id])

  @@map("contracts")
}

model Product {
  id          Int              @id @default(autoincrement())
  shopifyId   String           @unique @map("shopify_id")
  title       Json
  description Json?
  handle      String?
  vendor      String?
  productType String?          @map("product_type")
  status      String
  images      Json?
  syncedAt    DateTime         @default(now()) @map("synced_at")
  options     Json?
  variants    ProductVariant[]
  collections Collection[]     @relation("ProductToCollection")

  @@map("products")
}

model Collection {
  id        Int       @id @default(autoincrement())
  shopifyId String    @unique @map("shopify_id")
  handle    String    @unique
  title     String
  products  Product[] @relation("ProductToCollection")

  @@map("collections")
}

model Order {
  id                   Int         @id @default(autoincrement())
  dealerId             Int         @map("dealer_id")
  totalAmount          Decimal     @map("total_amount") @db.Decimal(10, 2)
  status               OrderStatus @default(draft)
  createdAt            DateTime    @default(now()) @map("created_at")
  updatedAt            DateTime    @updatedAt @map("updated_at")
  statusChangedByEmail String?     @map("status_changed_by_email")
  statusChangedAt      DateTime?   @map("status_changed_at")
  inventorySynced      Boolean     @default(false) @map("inventory_synced")
  inventorySyncedAt    DateTime?   @map("inventory_synced_at")
  notes                String?
  firstPaymentAmount   Decimal?    @map("first_payment_amount") @db.Decimal(10, 2)
  remainingAmount      Decimal?    @map("remaining_amount") @db.Decimal(10, 2)
  items                OrderItem[]
  dealer               Dealer      @relation(fields: [dealerId], references: [id])

  @@map("orders")
}

model OrderItem {
  id               Int            @id @default(autoincrement())
  orderId          Int            @map("order_id")
  productVariantId Int            @map("product_variant_id")
  quantity         Int
  unitPrice        Decimal        @map("unit_price") @db.Decimal(10, 2)
  order            Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productVariant   ProductVariant @relation(fields: [productVariantId], references: [id])

  @@map("order_items")
}

model ProductVariant {
  id                Int         @id @default(autoincrement())
  shopifyVariantId  String      @unique @map("shopify_variant_id")
  productId         Int         @map("product_id")
  title             Json
  sku               String?
  price             Decimal?
  compareAtPrice    Decimal?    @map("compare_at_price")
  inventoryQuantity Int?        @map("inventory_quantity")
  option1           String?
  option2           String?
  option3           String?
  imageUrl          String?     @map("image_url")
  orderItems        OrderItem[]
  product           Product     @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_variants")
}

model ExchangeRate {
  id        Int      @id @default(autoincrement())
  code      String   @unique
  rate      Decimal  @db.Decimal(18, 6)
  updatedAt DateTime @updatedAt

  @@map("exchange_rates")
}

enum Role {
  master_admin
  admin
  dealer
}

enum ContractStatus {
  pending
  approved
  rejected
  suspended
}

enum OrderStatus {
  draft
  pending_first_payment
  first_payment_received
  shipped
  received
  pending_rest_payment
  paid
  cancelled
}
