generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  master_admin
  admin
  dealer
}

enum ContractStatus {
  pending
  approved
  rejected
  suspended
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  role      Role     @default(dealer)
  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  dealer    Dealer?
}

model Dealer {
  id             Int            @id @default(autoincrement())
  userId         Int            @unique
  companyName    String
  phone          String?
  address        String?
  contractUrl    String?
  contractStatus ContractStatus @default(pending)
  statusChangedByEmail String?
  statusChangedAt      DateTime?
  createdAt            DateTime       @default(now())
  user                 User           @relation(fields: [userId], references: [id])
  orders         Order[]
  contracts      Contract[]
}

model Contract {
  id        Int            @id @default(autoincrement())
  dealerId  Int
  fileName  String
  fileUrl   String
  status    ContractStatus @default(pending)
  type      String
  notes     String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  dealer    Dealer         @relation(fields: [dealerId], references: [id])

  @@map("contracts")
}

model Product {
  id          Int              @id @default(autoincrement())
  shopifyId   String           @unique @map("shopify_id")
  title       Json
  description Json?
  handle      String?
  vendor      String?
  productType String?          @map("product_type")
  status      String
  images      Json?
  options     Json?
  syncedAt    DateTime         @default(now()) @map("synced_at")
  variants    ProductVariant[]
  collections Collection[]     @relation("ProductToCollection")

  @@map("products")
}

model Collection {
  id        Int       @id @default(autoincrement())
  shopifyId String    @unique @map("shopify_id")
  handle    String    @unique
  title     String
  products  Product[] @relation("ProductToCollection")

  @@map("collections")
}

enum OrderStatus {
  draft
  pending_payment
  paid
  shipped
  cancelled
}

model Order {
  id          Int         @id @default(autoincrement())
  dealerId    Int         @map("dealer_id")
  totalAmount Decimal     @map("total_amount") @db.Decimal(10, 2)
  status               OrderStatus @default(draft)
  statusChangedByEmail String?     @map("status_changed_by_email")
  statusChangedAt      DateTime?   @map("status_changed_at")
  createdAt            DateTime    @default(now()) @map("created_at")
  updatedAt            DateTime    @updatedAt @map("updated_at")
  dealer      Dealer      @relation(fields: [dealerId], references: [id])
  items       OrderItem[]

  @@map("orders")
}

model OrderItem {
  id               Int            @id @default(autoincrement())
  orderId          Int            @map("order_id")
  productVariantId Int            @map("product_variant_id")
  quantity         Int
  unitPrice        Decimal        @map("unit_price") @db.Decimal(10, 2)
  order            Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productVariant   ProductVariant @relation(fields: [productVariantId], references: [id])

  @@map("order_items")
}

model ProductVariant {
  id                Int         @id @default(autoincrement())
  shopifyVariantId  String      @unique @map("shopify_variant_id")
  productId         Int         @map("product_id")
  title             Json
  sku               String?
  price             Decimal?
  compareAtPrice    Decimal?    @map("compare_at_price")
  inventoryQuantity Int?        @map("inventory_quantity")
  option1           String?
  option2           String?
  option3           String?
  imageUrl          String?     @map("image_url")
  product           Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems        OrderItem[]

  @@map("product_variants")
}

model ExchangeRate {
  id        Int      @id @default(autoincrement())
  code      String   @unique // USD, EUR, TRY
  rate      Decimal  @db.Decimal(18, 6) // Rate relative to TRY (1.0 for TRY)
  updatedAt DateTime @updatedAt

  @@map("exchange_rates")
}
