generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  master_admin
  admin
  dealer
}

enum ContractStatus {
  pending
  approved
  rejected
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  role      Role     @default(dealer)
  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  dealer    Dealer?
}

model Dealer {
  id             Int            @id @default(autoincrement())
  userId         Int            @unique
  companyName    String
  phone          String?
  address        String?
  contractUrl    String?
  contractStatus ContractStatus @default(pending)
  createdAt      DateTime       @default(now())
  user           User           @relation(fields: [userId], references: [id])
}

model Product {
  id          Int              @id @default(autoincrement())
  shopifyId   String           @unique @map("shopify_id")
  title       String
  description String?
  handle      String?
  vendor      String?
  productType String?          @map("product_type")
  status      String
  images      Json?
  syncedAt    DateTime         @default(now()) @map("synced_at")
  variants    ProductVariant[]
  collections Collection[]     @relation("ProductToCollection")

  @@map("products")
}

model Collection {
  id        Int       @id @default(autoincrement())
  shopifyId String    @unique @map("shopify_id")
  handle    String    @unique
  title     String
  products  Product[] @relation("ProductToCollection")

  @@map("collections")
}

model ProductVariant {
  id                Int      @id @default(autoincrement())
  shopifyVariantId  String   @unique @map("shopify_variant_id")
  productId         Int      @map("product_id")
  title             String
  sku               String?
  price             Decimal?
  compareAtPrice    Decimal? @map("compare_at_price")
  inventoryQuantity Int?     @map("inventory_quantity")
  option1           String?
  option2           String?
  option3           String?
  imageUrl          String?  @map("image_url")
  product           Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_variants")
}
